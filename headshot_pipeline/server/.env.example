# FlashShot server — environment configuration (overseas build).
#
# Copy to `.env` and fill in. Values here are placeholders / safe defaults.
# The server reads this via pydantic-settings (config.py); see that file for
# the authoritative list of keys.

# ── Networking ────────────────────────────────────────
# Bind host/port for the FastAPI app. Behind Caddy on the shared VPS these are
# usually 127.0.0.1 + a non-conflicting port (e.g. 8001); Caddy reverse-proxies
# :443 → here.
HOST=127.0.0.1
PORT=8001
# CORS origins for the Next.js marketing/app site.
CORS_ORIGINS=["http://localhost:3000","https://flashshot.top","https://www.flashshot.top"]

# ── Security ──────────────────────────────────────────
# Secret for signing session owner-tokens. MUST be set in production so tokens
# survive restarts; generate with: python -c "import secrets;print(secrets.token_urlsafe(48))"
SESSION_SECRET_KEY=

# ── Payment: Paddle (Merchant of Record) ──────────────
# OFF by default. Set to 1 ONLY for local dev — mock mode auto-confirms
# payments after ~5s without touching Paddle, and MUST stay off in production.
PAYMENT_MOCK_ENABLED=0
# Get these from the Paddle dashboard (Developer Tools → Authentication +
# Notifications). Start with sandbox, flip ENVIRONMENT to production at launch.
PADDLE_ENVIRONMENT=sandbox
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
# Price IDs (pri_...) for the two paid tiers. Create one-time Products+Prices
# in the dashboard at $5 (Standard) and $10 (Pro); paste their price_ids here.
PADDLE_PRICE_STANDARD_ID=
PADDLE_PRICE_PREMIUM_ID=
# Where Paddle redirects the browser after a successful checkout.
PADDLE_RETURN_URL=https://flashshot.top
# Public webhook endpoint Paddle calls (must match what you register in the
# dashboard). The route is /api/payments/paddle/webhook — signature is
# HMAC-verified, no owner token required.
#   https://flashshot.top/api/payments/paddle/webhook

# ── Storage & retention ───────────────────────────────
# Root for uploads + generated output. Keep it OUTSIDE the repo (the working
# dir is rejected at startup to avoid scattering user face photos at the root).
DATA_DIR=/var/lib/flashshot/data
# Delete source + generated files N days after delivery (privacy + disk).
RETENTION_DAYS=7
MAX_FILE_SIZE_MB=10
MAX_PHOTOS=8
MIN_PHOTOS=2

# ── Generation backend switch ─────────────────────────
# Choose the Gemini driver:
#   openrouter → stateless REST API to google/gemini-3.1-flash-image-preview
#   chrome     → drive gemini.google.com via an already-running Chrome CDP
# The default is "openrouter"; set to "chrome" only when you have launched
# Chrome with "python persistent_client.py launch" and logged in manually.
GEMINI_BACKEND=openrouter

# Chrome backend settings (only used when GEMINI_BACKEND=chrome).
CHROME_CDP_PORT=9222
# CHROME_USER_DATA_DIR=/var/lib/flashshot/.chrome_profile
# CHROME_HEADLESS=false
CHROME_WAIT_TIMEOUT=120

# ── Generation backend: OpenRouter Gemini API ─────────
# The pipeline drives gemini-3.1-flash-image-preview ("Nano Banana 2") via the
# OpenRouter REST API. There is NO browser/Chrome layer when GEMINI_BACKEND
# is openrouter — generation is a stateless HTTPS call per turn. Set the key
# here; the worker refuses to start if it is empty and backend is openrouter.
#
# NEVER hardcode the key in source — it lives only in this gitignored .env.
OPENROUTER_API_KEY=
GEMINI_MODEL=google/gemini-3.1-flash-image-preview
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Per-call timeout for BOTH image generation and the resemblance-judge text
# turn. 180s is generous enough for a slow Nano Banana image turn.
GEMINI_WAIT_TIMEOUT=180

# ── Site config ───────────────────────────────────────
# China ICP filing number — leave EMPTY for the overseas build (the footer
# auto-hides the block when this is blank).
ICP_BEIAN=
