# FlashShot server — environment configuration (overseas build).
#
# Copy to `.env` and fill in. Values here are placeholders / safe defaults.
# The server reads this via pydantic-settings (config.py); see that file for
# the authoritative list of keys.

# ── Networking ────────────────────────────────────────
APP_ENVIRONMENT=development
# Bind host/port for the FastAPI app. Behind Caddy on the shared VPS these are
# usually 127.0.0.1 + a non-conflicting port (e.g. 8001); Caddy reverse-proxies
# :443 → here.
HOST=127.0.0.1
PORT=8001
# CORS origins for the Next.js marketing/app site.
CORS_ORIGINS=["http://localhost:3000","https://flashshot.top","https://www.flashshot.top"]

# ── Security ──────────────────────────────────────────
# Secret for signing session owner-tokens. MUST be set in production so tokens
# survive restarts; generate with: python -c "import secrets;print(secrets.token_urlsafe(48))"
SESSION_SECRET_KEY=
# Separate token for loopback/operations-only support endpoints. Use at least
# 32 random characters and never expose it to the website or iOS app.
SUPPORT_ADMIN_TOKEN=

# ── Payment: Paddle (Merchant of Record) ──────────────
# OFF by default. Set to 1 ONLY for local dev — mock mode auto-confirms
# payments after ~5s without touching Paddle, and MUST stay off in production.
PAYMENT_MOCK_ENABLED=0
# Get these from the Paddle dashboard (Developer Tools → Authentication +
# Notifications). Start with sandbox, flip ENVIRONMENT to production at launch.
PADDLE_ENVIRONMENT=sandbox
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_WEBHOOK_SECRET=
# Price IDs (pri_...) for the two paid tiers. Create one-time Products+Prices
# in the dashboard at $5 (Standard) and $10 (Pro); paste their price_ids here.
PADDLE_PRICE_STANDARD_ID=
PADDLE_PRICE_PREMIUM_ID=
# Where Paddle redirects the browser after a successful checkout.
PADDLE_RETURN_URL=https://flashshot.top/checkout

# Native iOS account + StoreKit 2 (primary launch payment path)
APPLE_CLIENT_ID=com.flashshot.app
APPLE_BUNDLE_ID=com.flashshot.app
APPLE_APP_ID=
APPLE_IAP_ENVIRONMENT=sandbox
APPLE_IAP_PRODUCT_ID=portrait_set_6
APPLE_ROOT_CERT_DIR=./config/apple-root-certs
# Public webhook endpoint Paddle calls (must match what you register in the
# dashboard). The route is /api/payments/paddle/webhook — signature is
# HMAC-verified, no owner token required.
#   https://flashshot.top/api/payments/paddle/webhook

# ── Storage & retention ───────────────────────────────
# Root for uploads + generated output. Keep it OUTSIDE the repo (the working
# dir is rejected at startup to avoid scattering user face photos at the root).
DATA_DIR=/var/lib/flashshot/data
# Layered retention measured from project/session creation.
SOURCE_RETENTION_DAYS=7
GENERATED_RETENTION_DAYS=30
METADATA_RETENTION_DAYS=90
MAX_FILE_SIZE_MB=10
MAX_PHOTOS=6
MIN_PHOTOS=4

# ── Generation backend switch ─────────────────────────
# Choose the Gemini driver:
#   openrouter → dedicated OpenRouter Image API + independent VLM judge
#   siliconflow → Qwen-Image-Edit generation + Qwen-VL quality judge
#   chrome      → drive gemini.google.com via an already-running Chrome CDP
# Production currently uses the stateless OpenRouter backend proven by the
# destructive six-photo E2E. SiliconFlow remains an explicit fallback.
GEMINI_BACKEND=openrouter

# Chrome backend settings (only used when GEMINI_BACKEND=chrome).
CHROME_CDP_PORT=9222
# CHROME_USER_DATA_DIR=/var/lib/flashshot/.chrome_profile
# CHROME_HEADLESS=false
CHROME_WAIT_TIMEOUT=120

# ── OpenRouter image backend (current production primary) ────────────
# Seedream generation uses OpenRouter's dedicated /images endpoint. QA uses a
# separate multimodal text model, preventing generator self-scoring.
#
# NEVER hardcode the key in source — it lives only in this gitignored .env.
OPENROUTER_API_KEY=
GEMINI_MODEL=bytedance-seed/seedream-4.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_JUDGE_MODEL=qwen/qwen3-vl-32b-instruct
OPENROUTER_IMAGE_PROVIDER=seed
OPENROUTER_IMAGE_SIZE=1728x2304
OPENROUTER_ESTIMATED_IMAGE_COST=0.04
# Identity-first Hero route. It is deliberately separate from the wider-set
# model so the first preview never goes through scaffold + local face swap.
OPENROUTER_HERO_MODEL=black-forest-labs/flux.2-pro
OPENROUTER_RECOVERY_MODEL=
OPENROUTER_RECOVERY_IMAGE_PROVIDER=
OPENROUTER_RECOVERY_ESTIMATED_IMAGE_COST=0.15
OPENROUTER_HERO_IMAGE_PROVIDER=black-forest-labs
OPENROUTER_HERO_ESTIMATED_IMAGE_COST=0.12
HERO_IDENTITY_COSINE_ACCEPT_THRESHOLD=0.78
HERO_IDENTITY_COSINE_REFERENCE_FLOOR=0.76
OPENROUTER_MIN_CREDIT_BALANCE=3.0
OPENROUTER_MAX_REFERENCE_IMAGES=5
# Per-call timeout for image generation and the quality-judge text turn.
GEMINI_WAIT_TIMEOUT=180

# ── SiliconFlow image backend ─────────────────────────
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_IMAGE_MODEL=Qwen/Qwen-Image-Edit-2509
SILICONFLOW_TEXT_TO_IMAGE_MODEL=Qwen/Qwen-Image
SILICONFLOW_JUDGE_MODEL=Qwen/Qwen2.5-VL-32B-Instruct
SILICONFLOW_ESTIMATED_IMAGE_COST=0.05

# Local identity write used by the composition-first half/full-body pipeline.
# Keep the model outside git, deploy it with mode 0644, and use an absolute path
# so release directories and systemd working directories cannot change it.
FACE_SWAP_ENABLED=1
FACE_SWAP_MODEL_PATH=/opt/flashshot/models/inswapper_128.onnx

# ── Site config ───────────────────────────────────────
# China ICP filing number — leave EMPTY for the overseas build (the footer
# auto-hides the block when this is blank).
ICP_BEIAN=
